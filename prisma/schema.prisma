// Global Freight Calculator — Database Schema
// PostgreSQL via Supabase. Run `npx prisma migrate dev` after setting DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
  USER
}

enum CargoType {
  FCL
  LCL
  RORO
  VEHICLE
  AIR
  RAIL
}

enum ContainerSize {
  TWENTY_GP
  FORTY_GP
  FORTY_HQ
  FORTY_FIVE_HQ
}

enum VehicleType {
  SUV
  SEDAN
  PICKUP
  TRUCK
  BUS
  EV
  HYBRID
}

enum DrivingSide {
  LEFT
  RIGHT
}

enum BlogCategory {
  IMPORT
  EXPORT
  SHIPPING
  FREIGHT
  AUTOMOBILE_EXPORT
  TRADE_GUIDE
}

model User {
  id            String   @id @default(cuid())
  supabaseUid   String   @unique
  email         String   @unique
  name          String?
  role          Role     @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  blogPosts     BlogPost[]

  @@map("users")
}

model Country {
  id                String       @id @default(cuid())
  name              String       @unique
  isoCode           String       @unique // ISO 3166-1 alpha-2
  region            String
  subregion         String?
  currency          String
  voltage           String
  drivingSide       DrivingSide
  importDutyRate    Float        @default(0) // percentage — see tariffVerified
  vatRate           Float        @default(0) // percentage — see tariffVerified
  tariffVerified    Boolean      @default(false) // false = regional-average placeholder, not sourced from an authoritative tariff database yet
  requiresInspection Boolean     @default(false)
  requiredDocuments String[]
  ports             Port[]
  exchangeRate      ExchangeRate?
  taxTables         TaxTable[]

  @@map("countries")
  @@index([region])
}

model Port {
  id                 String    @id @default(cuid())
  name               String
  unlocode           String    @unique
  countryId          String
  country            Country   @relation(fields: [countryId], references: [id], onDelete: Cascade)
  latitude            Float
  longitude           Float
  nearbyAirports      String[]
  nearbyWarehouses    String[]
  roroAvailable       Boolean   @default(false)
  containerAvailable  Boolean   @default(true)
  originRates         FreightRate[] @relation("OriginPort")
  destinationRates    FreightRate[] @relation("DestinationPort")
  portCharges         PortCharge[]
  capability          PortCapability?
  routesAsOrigin      ShippingRoute[] @relation("RouteOrigin")
  routesAsDestination ShippingRoute[] @relation("RouteDestination")

  @@map("ports")
  @@index([countryId])
}

/// Detailed operational capability profile for a port, kept separate from
/// the Port model so it can grow (new capability fields) without touching
/// the core port record or its many relations.
model PortCapability {
  id                    String   @id @default(cuid())
  portId                String   @unique
  port                  Port     @relation(fields: [portId], references: [id], onDelete: Cascade)
  annualTeuCapacity     Int?     // approximate throughput capacity, TEU/year
  maxVesselLoaM         Float?   // max vessel length overall the port can berth, meters
  maxDraftM             Float?   // max channel/berth draft, meters
  reeferPlugs           Int?     // number of refrigerated container plugs available
  roroRampCapacityTons  Float?   // max ramp weight for RoRo vehicle discharge
  bondedWarehouse       Boolean  @default(false)
  railConnected         Boolean  @default(false)
  customsBrokerOnSite   Boolean  @default(false)
  hazmatHandling        Boolean  @default(false)
  updatedAt             DateTime @updatedAt

  @@map("port_capabilities")
}

model ShippingLine {
  id               String   @id @default(cuid())
  name             String   @unique
  slug             String   @unique
  website          String
  trackingUrl      String
  coverageRegions  String[]
  offersContainer  Boolean  @default(true)
  offersRoro       Boolean  @default(false)
  description      String
  freightRates     FreightRate[]
  shippingRoutes   ShippingRoute[]

  @@map("shipping_lines")
}

/// A named sailing service/rotation (e.g. "Asia-West Africa Express")
/// operated by a shipping line between two anchor ports, optionally calling
/// at intermediate ports. FreightRate rows reference a route when the price
/// is tied to a specific scheduled service rather than a generic lane.
model ShippingRoute {
  id                  String        @id @default(cuid())
  name                String
  shippingLineId      String
  shippingLine        ShippingLine  @relation(fields: [shippingLineId], references: [id], onDelete: Cascade)
  originPortId        String
  originPort          Port          @relation("RouteOrigin", fields: [originPortId], references: [id], onDelete: Cascade)
  destinationPortId   String
  destinationPort     Port          @relation("RouteDestination", fields: [destinationPortId], references: [id], onDelete: Cascade)
  intermediatePortIds String[]      // ordered list of Port ids called at along the rotation
  frequencyDays       Int           // sailing frequency, e.g. 7 = weekly
  transitDays         Int
  active              Boolean       @default(true)
  freightRates        FreightRate[]

  @@map("shipping_routes")
  @@index([originPortId, destinationPortId])
}

model FreightRate {
  id                 String         @id @default(cuid())
  originPortId       String
  originPort         Port           @relation("OriginPort", fields: [originPortId], references: [id], onDelete: Cascade)
  destinationPortId  String
  destinationPort    Port           @relation("DestinationPort", fields: [destinationPortId], references: [id], onDelete: Cascade)
  shippingLineId     String
  shippingLine       ShippingLine   @relation(fields: [shippingLineId], references: [id], onDelete: Cascade)
  shippingRouteId     String?
  shippingRoute       ShippingRoute? @relation(fields: [shippingRouteId], references: [id], onDelete: SetNull)
  cargoType          CargoType
  containerSize      ContainerSize?
  baseRatePerUnit    Float
  transitDays        Int
  effectiveFrom      DateTime       @default(now())
  effectiveTo        DateTime?

  @@map("freight_rates")
  @@index([originPortId, destinationPortId, cargoType])
}

model VehicleTypeProfile {
  id                String      @id @default(cuid())
  type              VehicleType @unique
  avgLengthM        Float
  avgWidthM         Float
  avgHeightM        Float
  avgWeightKg       Float
  baseRoroRate      Float // base rate multiplier for RoRo calculator

  @@map("vehicle_type_profiles")
}

/// Specific make/model catalog entry, used to give the RoRo calculator exact
/// dimensions instead of only a generic VehicleTypeProfile category average.
model VehicleModel {
  id          String      @id @default(cuid())
  make        String
  model       String
  variant     String?
  vehicleType VehicleType
  lengthM     Float
  widthM      Float
  heightM     Float
  weightKg    Float
  isEV        Boolean     @default(false)
  modelYear   Int?

  @@unique([make, model, variant])
  @@map("vehicle_models")
  @@index([vehicleType])
}

model ContainerTypeProfile {
  id            String        @id @default(cuid())
  size          ContainerSize @unique
  maxCbm        Float
  maxPayloadKg  Float
  internalLenM  Float
  internalWidM  Float
  internalHgtM  Float

  @@map("container_type_profiles")
}

model PortCharge {
  id                  String   @id @default(cuid())
  portId              String
  port                Port     @relation(fields: [portId], references: [id], onDelete: Cascade)
  documentationFee    Float    @default(0)
  inspectionFee       Float    @default(0)
  terminalHandlingFee Float    @default(0)
  customsClearanceFee Float    @default(0)

  @@map("port_charges")
  @@index([portId])
}

model TaxTable {
  id             String   @id @default(cuid())
  countryId      String
  country        Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  hsCodePrefix   String? // optional HS-code-specific override
  importDutyRate Float
  vatRate        Float
  notes          String?

  @@map("tax_tables")
  @@index([countryId])
}

model ExchangeRate {
  id           String   @id @default(cuid())
  countryId    String   @unique
  country      Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  currency     String
  rateToUsd    Float
  updatedAt    DateTime @updatedAt

  @@map("exchange_rates")
}

model BlogPost {
  id              String       @id @default(cuid())
  slug            String       @unique
  title           String
  excerpt         String
  content         String       @db.Text
  category        BlogCategory
  coverImage      String?
  authorId        String
  author          User         @relation(fields: [authorId], references: [id])
  publishedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  readingTimeMinutes Int       @default(5)

  @@map("blog_posts")
  @@index([category])
  @@index([slug])
}
